{
  "name": "metacli-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Unified orchestration CLI for AI coding CLIs",
  "author": "MetaCLI",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules package-lock.json",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react-is": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
