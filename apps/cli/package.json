{
  "name": "metacli",
  "version": "1.0.0-alpha.1",
  "description": "MetaCLI — Persistent Cognitive Engineering Intelligence",
  "type": "module",
  "bin": {
    "metacli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@metacli/adapters": "*",
    "@metacli/brain": "*",
    "@metacli/core": "*",
    "@metacli/telemetry": "*",
    "@metacli/workflow": "*",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
